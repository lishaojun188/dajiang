  "matching_rules": {
    "description": "标签匹配规则 - 用于判断新闻与关注领域的相关度",

    "scoring": {
      "person_match": {
        "critical_person": 5,
        "high_person": 3,
        "medium_person": 2,
        "low_person": 1
      },
      "product_match": {
        "critical_product": 5,
        "high_product": 3,
        "medium_product": 2,
        "low_product": 1
      },
      "industry_match": {
        "primary_industry": 4,
        "secondary_industry": 2
      },
      "company_match": {
        "tier1_company": 5,
        "tier2_company": 3,
        "tier3_company": 2
      }
    },

    "threshold": {
      "create_task": 3,
      "high_priority_task": 8,
      "critical_task": 12
    },

    "notes": "最终相关度分数 = person_match + product_match + industry_match + company_match。分数 >= 3 创建任务，>= 8 高优先级，>= 12 关键任务。"
  }
}
