  "fetch_config": {
    "webfetch": {
      "timeout_ms": 30000,
      "retry_count": 1,
      "headers": {
        "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8"
      }
    },
    "browser": {
      "timeout_ms": 45000,
      "wait_for_selector": "article, .post, .item, .feed-item",
      "screenshot_on_error": true
    }
  },

  "quality_thresholds": {
    "min_score_to_include": 3,
    "target_items": 15,
    "early_stop_threshold": 20
  }
